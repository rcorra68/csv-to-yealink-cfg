[*]
# Explicitly set English (US) as the primary language, Italian as secondary
spelling_languages = en-us,it-it
spelling_checkable_types = comments
spelling_error_severity = suggestion

[*.cs]
# Force English as the ONLY language for C# comments to avoid Italian suggestions
spelling_languages = en-us
spelling_checkable_types = comments
spelling_exclude_identifiers = true
spelling_include_comments = true